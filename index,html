
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="The Beauty Drop - Luxury Beauty Essentials Designed For Everyday Confidence. Premium skincare, makeup and beauty products.">
<meta name="keywords" content="luxury beauty, skincare, makeup, cosmetics, premium beauty, Lebanon">
<title>THE BEAUTY DROP | Luxury Beauty Essentials</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Jost:wght@200;300;400;500;600&family=Noto+Kufi+Arabic:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --white: #FFFFFF;
    --lavender: #F3EEFF;
    --accent: #C9A4FF;
    --accent-dark: #9B6FD4;
    --accent-deep: #7B4FBF;
    --text-dark: #1a1a2e;
    --text-mid: #4a4a6a;
    --text-light: #8a8aaa;
    --glass-bg: rgba(255,255,255,0.55);
    --glass-border: rgba(201,164,255,0.25);
    --shadow-soft: 0 8px 40px rgba(155,111,212,0.12);
    --shadow-deep: 0 20px 60px rgba(155,111,212,0.2);
    --gradient-main: linear-gradient(135deg, #F3EEFF 0%, #EDE0FF 40%, #F9F4FF 100%);
    --gradient-accent: linear-gradient(135deg, #C9A4FF 0%, #9B6FD4 50%, #7B4FBF 100%);
    --gradient-btn: linear-gradient(135deg, #C9A4FF 0%, #9B6FD4 100%);
    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Jost', sans-serif;
    --font-arabic: 'Noto Kufi Arabic', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    font-family: var(--font-sans);
    background: var(--white);
    color: var(--text-dark);
    overflow-x: hidden;
    cursor: none;
  }

  body.arabic {
    font-family: var(--font-arabic);
    direction: rtl;
  }

  /* ─── CUSTOM CURSOR ─── */
  .cursor-dot {
    width: 8px; height: 8px;
    background: var(--accent-dark);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99999;
    transition: transform 0.1s ease;
    transform: translate(-50%,-50%);
  }

  .cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid rgba(155,111,212,0.5);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99998;
    transition: transform 0.15s ease, width 0.3s ease, height 0.3s ease, background 0.3s ease;
    transform: translate(-50%,-50%);
  }

  .cursor-ring.hovering {
    width: 55px; height: 55px;
    background: rgba(201,164,255,0.1);
    border-color: var(--accent);
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--lavender); }
  ::-webkit-scrollbar-thumb { background: var(--gradient-accent); border-radius: 10px; }

  /* ─── PARTICLES ─── */
  #particles-container {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,164,255,0.4), transparent);
    animation: floatParticle linear infinite;
    pointer-events: none;
  }

  @keyframes floatParticle {
    0% { transform: translateY(100vh) scale(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-100px) scale(1); opacity: 0; }
  }

  /* ─── NAVBAR ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 0 60px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201,164,255,0.15);
    transition: all 0.4s ease;
  }

  nav.scrolled {
    height: 70px;
    background: rgba(255,255,255,0.88);
    box-shadow: 0 4px 30px rgba(155,111,212,0.1);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo img {
    height: 46px;
    width: auto;
    object-fit: contain;
    border-radius: 8px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-mid);
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--gradient-accent);
    transition: width 0.35s ease;
  }

  .nav-links a:hover { color: var(--accent-dark); }
  .nav-links a:hover::after { width: 100%; }

  .nav-icons {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .nav-icon-btn {
    background: none;
    border: none;
    cursor: none;
    color: var(--text-mid);
    font-size: 18px;
    padding: 8px;
    border-radius: 50%;
    transition: all 0.3s ease;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon-btn:hover {
    color: var(--accent-dark);
    background: rgba(201,164,255,0.12);
  }

  .cart-badge {
    position: absolute;
    top: 2px; right: 2px;
    width: 16px; height: 16px;
    background: var(--gradient-accent);
    border-radius: 50%;
    font-size: 9px;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    background: rgba(243,238,255,0.8);
    border: 1px solid rgba(201,164,255,0.3);
    border-radius: 20px;
    overflow: hidden;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .lang-btn {
    padding: 5px 12px;
    cursor: none;
    background: transparent;
    border: none;
    color: var(--text-light);
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .lang-btn.active {
    background: var(--gradient-accent);
    color: white;
    border-radius: 18px;
  }

  .lang-divider {
    color: rgba(201,164,255,0.5);
    font-size: 11px;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: none;
    background: none;
    border: none;
    padding: 5px;
  }

  .hamburger span {
    display: block;
    width: 24px; height: 1.5px;
    background: var(--text-mid);
    transition: all 0.3s ease;
  }

  /* ─── MOBILE MENU ─── */
  .mobile-menu {
    position: fixed;
    top: 80px; left: 0; right: 0; bottom: 0;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(30px);
    z-index: 999;
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.77,0,0.175,1);
    display: flex;
    flex-direction: column;
    padding: 50px 40px;
    gap: 30px;
  }

  .mobile-menu.open { transform: translateX(0); }

  .mobile-menu a {
    text-decoration: none;
    font-size: 24px;
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--text-dark);
    letter-spacing: 1px;
    transition: color 0.3s;
    border-bottom: 1px solid rgba(201,164,255,0.2);
    padding-bottom: 20px;
  }

  .mobile-menu a:hover { color: var(--accent-dark); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    background: var(--gradient-main);
    padding-top: 80px;
  }

  .hero-bg-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-shapes .shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: morphShape 8s ease-in-out infinite alternate;
  }

  .shape-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(201,164,255,0.25) 0%, transparent 70%);
    top: -150px; right: -100px;
    animation-duration: 10s;
  }

  .shape-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(155,111,212,0.15) 0%, transparent 70%);
    bottom: -100px; left: 100px;
    animation-duration: 7s;
    animation-delay: -3s;
  }

  .shape-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(243,238,255,0.8) 0%, transparent 70%);
    top: 50%; left: 30%;
    animation-duration: 9s;
    animation-delay: -5s;
  }

  @keyframes morphShape {
    0% { transform: translate(0,0) scale(1); }
    100% { transform: translate(30px, 30px) scale(1.1); }
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 80px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hero-text { animation: heroTextIn 1.2s cubic-bezier(0.16,1,0.3,1) both; }

  @keyframes heroTextIn {
    0% { opacity: 0; transform: translateY(60px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 24px;
  }

  .hero-eyebrow::before, .hero-eyebrow::after {
    content: '';
    width: 30px; height: 1px;
    background: var(--accent);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(52px, 6vw, 88px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--text-dark);
    margin-bottom: 12px;
    letter-spacing: -1px;
  }

  .hero-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-dark);
  }

  .hero-title .hero-title-drop {
    display: block;
    font-size: clamp(60px, 7.5vw, 110px);
    font-weight: 600;
    letter-spacing: -3px;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-mid);
    margin: 24px 0 40px;
    max-width: 420px;
    letter-spacing: 0.3px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: var(--gradient-btn);
    color: white;
    border: none;
    border-radius: 50px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: none;
    text-decoration: none;
    transition: all 0.4s ease;
    box-shadow: 0 8px 30px rgba(155,111,212,0.35);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 45px rgba(155,111,212,0.5);
  }

  .btn-primary:hover::before { opacity: 1; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: transparent;
    color: var(--accent-dark);
    border: 1.5px solid rgba(155,111,212,0.4);
    border-radius: 50px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: none;
    text-decoration: none;
    transition: all 0.4s ease;
    backdrop-filter: blur(10px);
  }

  .btn-secondary:hover {
    background: rgba(201,164,255,0.12);
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(155,111,212,0.15);
  }

  /* Ripple */
  .ripple-effect {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    transform: scale(0);
    animation: ripple 0.6s linear;
    pointer-events: none;
  }

  @keyframes ripple {
    to { transform: scale(4); opacity: 0; }
  }

  /* ─── HERO VISUAL ─── */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 580px;
    animation: heroVisualIn 1.4s cubic-bezier(0.16,1,0.3,1) 0.2s both;
  }

  @keyframes heroVisualIn {
    0% { opacity: 0; transform: translateY(40px) scale(0.95); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hero-glow-ring {
    position: absolute;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,164,255,0.3) 0%, transparent 70%);
    animation: pulseGlow 4s ease-in-out infinite;
    filter: blur(20px);
  }

  @keyframes pulseGlow {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  .hero-main-product {
    position: relative;
    z-index: 3;
    width: 280px; height: 380px;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(155,111,212,0.3), 0 0 0 1px rgba(255,255,255,0.5);
    animation: floatMain 6s ease-in-out infinite;
    transform-style: preserve-3d;
  }

  @keyframes floatMain {
    0%, 100% { transform: translateY(0px) rotate(-2deg); }
    50% { transform: translateY(-20px) rotate(2deg); }
  }

  .hero-main-product img {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .hero-floating-card {
    position: absolute;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(201,164,255,0.3);
    border-radius: 20px;
    padding: 12px 16px;
    box-shadow: 0 10px 40px rgba(155,111,212,0.15);
    z-index: 4;
  }

  .float-card-1 {
    top: 60px; left: -20px;
    animation: floatCard1 5s ease-in-out infinite;
  }

  .float-card-2 {
    bottom: 80px; right: -30px;
    animation: floatCard2 6s ease-in-out infinite;
    animation-delay: -2s;
  }

  .float-card-3 {
    top: 180px; right: -50px;
    animation: floatCard3 7s ease-in-out infinite;
    animation-delay: -1s;
  }

  @keyframes floatCard1 {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-12px) translateX(5px); }
  }

  @keyframes floatCard2 {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-10px) rotate(2deg); }
  }

  @keyframes floatCard3 {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-15px) translateX(-5px); }
  }

  .float-card-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-light);
    font-weight: 500;
  }

  .float-card-value {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--text-dark);
    margin-top: 3px;
  }

  .float-card-stars { color: #C9A4FF; font-size: 12px; margin-top: 2px; }

  .hero-mini-products {
    position: absolute;
    bottom: 30px; left: -60px;
    display: flex;
    gap: 10px;
    animation: floatMini 5s ease-in-out infinite;
    animation-delay: -3s;
  }

  @keyframes floatMini {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .mini-product-thumb {
    width: 52px; height: 68px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(155,111,212,0.2);
    border: 2px solid rgba(255,255,255,0.8);
    animation: floatMain 5s ease-in-out infinite;
  }

  .mini-product-thumb:nth-child(2) { animation-delay: -1s; }
  .mini-product-thumb:nth-child(3) { animation-delay: -2s; }

  .mini-product-thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* ─── SECTION COMMON ─── */
  section { position: relative; z-index: 1; }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 16px;
  }

  .section-eyebrow::before, .section-eyebrow::after {
    content: '';
    width: 40px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent));
  }

  .section-eyebrow::after {
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4vw, 58px);
    font-weight: 300;
    color: var(--text-dark);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }

  .section-title em {
    font-style: italic;
    color: var(--accent-dark);
  }

  .section-subtitle {
    font-size: 15px;
    color: var(--text-light);
    font-weight: 300;
    margin-top: 12px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  /* ─── FEATURES ─── */
  .features {
    padding: 100px 80px;
    background: var(--white);
  }

  .features-grid {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  .feature-card {
    text-align: center;
    padding: 44px 32px;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    transition: all 0.5s cubic-bezier(0.16,1,0.3,1);
    cursor: default;
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(201,164,255,0.12), transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 60px rgba(155,111,212,0.18);
    border-color: rgba(201,164,255,0.4);
  }

  .feature-card:hover::before { opacity: 1; }

  .feature-icon-wrap {
    width: 80px; height: 80px;
    margin: 0 auto 24px;
    border-radius: 50%;
    background: var(--gradient-main);
    border: 1px solid rgba(201,164,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    transition: all 0.4s ease;
    box-shadow: 0 8px 25px rgba(155,111,212,0.15);
  }

  .feature-card:hover .feature-icon-wrap {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 15px 40px rgba(155,111,212,0.25);
  }

  .feature-card h3 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--text-dark);
    margin-bottom: 10px;
  }

  .feature-card p {
    font-size: 13px;
    color: var(--text-light);
    line-height: 1.7;
    font-weight: 300;
  }

  /* ─── PRODUCTS ─── */
  .best-sellers {
    padding: 100px 80px;
    background: var(--lavender);
    position: relative;
  }

  .best-sellers::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
  }

  .products-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
  }

  .product-card {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.9);
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(155,111,212,0.08);
    transition: all 0.5s cubic-bezier(0.16,1,0.3,1);
    cursor: none;
    transform-style: preserve-3d;
    perspective: 1000px;
    position: relative;
  }

  .product-card:hover {
    transform: translateY(-15px);
