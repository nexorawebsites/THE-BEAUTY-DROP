      d.className = 'rev-dot' + (idx === 0 ? ' on' : '');
      d.setAttribute('aria-label', 'Go to slide ' + (idx + 1));
      d.addEventListener('click', function() { go(idx); });
      dotsWrap.appendChild(d);
    })(i);
  }

  function go(idx) {
    cur = ((idx % groups) + groups) % groups;
    var w = track.parentElement.offsetWidth;
    track.style.transform = 'translateX(-' + (cur * w) + 'px)';
    dotsWrap.querySelectorAll('.rev-dot').forEach(function(d, i) {
      d.classList.toggle('on', i === cur);
    });
  }

  document.getElementById('revPrev').addEventListener('click', function() { go(cur - 1); });
  document.getElementById('revNext').addEventListener('click', function() { go(cur + 1); });

  var autoSlide = setInterval(function() { go(cur + 1); }, 5500);

  track.parentElement.addEventListener('mouseenter', function() { clearInterval(autoSlide); });
  track.parentElement.addEventListener('mouseleave', function() {
    autoSlide = setInterval(function() { go(cur + 1); }, 5500);
  });

  window.addEventListener('resize', function() {
    perView = window.innerWidth < 520 ? 1 : window.innerWidth < 860 ? 2 : 3;
    go(0);
  });
})();

