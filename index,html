// ── CURSOR ──
var cDot = document.getElementById('cDot');
var cRing = document.getElementById('cRing');
var mx = 0, my = 0, rx = 0, ry = 0;

if (cDot && cRing) {
  document.addEventListener('mousemove', function(e) {
    mx = e.clientX; my = e.clientY;
    cDot.style.left = mx + 'px';
    cDot.style.top = my + 'px';
  });
  (function tick() {
    rx += (mx - rx) * 0.13;
    ry += (my - ry) * 0.13;
    cRing.style.left = rx + 'px';
    cRing.style.top = ry + 'px';
    requestAnimationFrame(tick);
  })();
  document.querySelectorAll('a,button,.prod-card,.coll-card,.ig-item,.feat-card').forEach(function(el) {
    el.addEventListener('mouseenter', function() { cRing.classList.add('grow'); });
    el.addEventListener('mouseleave', function() { cRing.classList.remove('grow'); });
  });
  document.body.style.cursor = 'none';
}

// ── PETALS ──
(function() {
